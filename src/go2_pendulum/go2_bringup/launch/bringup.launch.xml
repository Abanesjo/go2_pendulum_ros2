<?xml version="1.0"?>
<launch>
    <arg name="bridge" default="true"/>
    <arg name="description" default="false"/>
    <arg name="vicon" default="true"/>
    <arg name="joy" default="true"/>
    <arg name="navigation" default="true"/>
    <arg name="rviz" default="true"/>
    <arg name="lowcmd_publish_rate_hz" default="500.0"/>
    <arg name="unitree_lowcmd_qos_reliability" default="best_effort"/>
    <arg name="model_file" default="$(find-pkg-share go2_bringup)/model/policy.onnx"/>

    <!-- Robot description / robot_state_publisher. Opt-in on hardware because
         this DDS participant can destabilize Unitree discovery on restart. -->
    <group if="$(var description)">
        <include file="$(find-pkg-share go2_description)/launch/go2_description.launch.xml"/>
    </group>

    <!-- Vicon -->
    <group if="$(var vicon)">
        <include file="$(find-pkg-share vicon_receiver)/launch/client.launch.xml"/>
    </group>

    <!-- Unitree Bridge -->
    <group if="$(var bridge)">
        <node pkg="go2_bridge" exec="go2_bridge_node" name="go2_bridge_node" output="screen">
            <param from="$(find-pkg-share go2_bridge)/config/gains.yaml"/>
            <param name="lowcmd_publish_rate_hz" value="$(var lowcmd_publish_rate_hz)"/>
            <param name="unitree_lowcmd_qos_reliability" value="$(var unitree_lowcmd_qos_reliability)"/>
        </node>
    </group>

    <!-- RL controller (C++ node with ONNX inference) -->
    <node pkg="go2_bringup" exec="rl_controller_node" name="rl_controller_node" output="screen">
        <param from="$(find-pkg-share go2_bringup)/config/config.yaml"/>
        <param name="model_path" value="$(var model_file)"/>
    </node>

    <!-- Joystick input -->
    <group if="$(var joy)">
        <node pkg="joy" exec="joy_node" name="joy_node" output="screen"/>

        <!-- Joy safety/start orchestrator -->
        <node pkg="go2_bringup" exec="joy_orchestrator_node.py" name="joy_orchestrator_node" output="screen"/>
    </group>

    <!-- Waypoint navigation -->
    <group if="$(var navigation)">
        <node pkg="go2_navigation" exec="waypoint_manager_node" name="waypoint_manager_node" output="screen">
            <param from="$(find-pkg-share go2_navigation)/config/nav.yaml"/>
        </node>
    </group>

    <!-- rviz -->
    <group if="$(var rviz)">
        <node pkg="rviz2" exec="rviz2" name="rviz" args="-d $(find-pkg-share go2_bringup)/rviz/config.rviz"/>
    </group>
</launch>
